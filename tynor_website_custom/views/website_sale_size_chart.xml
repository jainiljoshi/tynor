<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template
        id="tynor_website_product_size_chart_and_bulk_order"
        inherit_id="website_sale.product"
        priority="70"
        name="Tynor Product Size Chart and Bulk Size Order"
    >
        <xpath expr="//t[@name='variant_info']" position="before">
            <div
                t-if="product.tynor_size_chart_image"
                class="tynor-size-chart-trigger o_wsale_product_details_content_section mb-3"
            >
                <button
                    type="button"
                    class="btn btn-outline-secondary btn-sm"
                    data-bs-toggle="modal"
                    t-att-data-bs-target="'#tynor_size_chart_modal_%s' % product.id"
                >
                    <i class="fa fa-ruler me-1"/>
                    <t t-out="product.tynor_size_chart_title or 'Size Chart'"/>
                </button>
                <div
                    t-att-id="'tynor_size_chart_modal_%s' % product.id"
                    class="modal fade tynor-size-chart-modal"
                    tabindex="-1"
                    aria-hidden="true"
                >
                    <div class="modal-dialog modal-dialog-centered tynor-size-chart-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title" t-out="product.tynor_size_chart_title or 'Size Chart'"/>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"/>
                            </div>
                            <div class="modal-body text-center">
                                <img
                                    class="img-fluid rounded"
                                    t-att-src="'/web/image/product.template/%s/tynor_size_chart_image' % product.id"
                                    t-att-alt="product.tynor_size_chart_title or 'Size Chart'"
                                />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>

        <xpath expr="//div[@id='o_wsale_product_cta_section']" position="after">
            <t t-set="tynor_bulk_size_ctx" t-value="product._tynor_get_bulk_size_context()"/>
            <div
                t-if="not request.env.user._is_public() and product.tynor_enable_bulk_size_order and tynor_bulk_size_ctx['options']"
                class="tynor-bulk-size-order o_wsale_product_details_content_section mb-4 js_tynor_bulk_size_order"
                t-att-data-product-template-id="product.id"
                t-att-data-currency-symbol="tynor_bulk_size_ctx.get('currency_symbol')"
                t-att-data-currency-position="tynor_bulk_size_ctx.get('currency_position')"
                t-att-data-currency-decimals="tynor_bulk_size_ctx.get('currency_decimals')"
            >
                <div class="small text-muted">
                    Fast wholesale order: click <strong>Add to cart</strong> above, enter quantities for all sizes in one popup, then add all at once.
                </div>
            </div>
            <div
                t-if="not request.env.user._is_public() and product.tynor_enable_bulk_size_order and tynor_bulk_size_ctx['options']"
                id="tynor_bulk_order_modal"
                class="modal fade"
                tabindex="-1"
                aria-hidden="true"
            >
                <div class="modal-dialog modal-dialog-centered modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Quick Size Order</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"/>
                        </div>
                        <div class="modal-body js_tynor_bulk_modal_body">
                            <div class="small text-muted mb-2">
                                Enter quantity for each <t t-out="tynor_bulk_size_ctx.get('size_attribute_label') or 'size'"/> and add all in one click.
                            </div>
                            <div class="small text-muted mb-3 js_tynor_bulk_summary">Types: none | Total Qty: 0 | Total: 0</div>
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0">
                                    <thead>
                                        <tr>
                                            <th><t t-out="tynor_bulk_size_ctx.get('size_attribute_label') or 'Size'"/></th>
                                            <th class="text-center">Qty</th>
                                            <th class="text-end">Price</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="tynor_bulk_size_ctx['options']" t-as="size_opt">
                                            <td>
                                                <span t-out="size_opt['label']"/>
                                            </td>
                                            <td class="text-center">
                                                <input
                                                    type="number"
                                                    min="0"
                                                    step="1"
                                                    value="0"
                                                    class="form-control form-control-sm tynor-size-qty-input js_tynor_size_qty"
                                                    t-att-data-ptav-id="size_opt['ptav_id']"
                                                    t-att-data-size-label="size_opt['label']"
                                                />
                                            </td>
                                            <td class="text-end fw-semibold js_tynor_size_price" t-att-data-ptav-id="size_opt['ptav_id']">-</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <div class="small mt-2 js_tynor_bulk_message d-none"/>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-outline-secondary js_tynor_bulk_clear">Clear</button>
                            <button type="button" class="btn btn-primary js_tynor_bulk_add_modal">Add All to Cart</button>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </template>
</odoo>
