<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tynor_ndis_order_tree" model="ir.ui.view">
        <field name="name">tynor.ndis.order.list</field>
        <field name="model">tynor.ndis.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="ndis_number"/>
                <field name="participant_name"/>
                <field name="plan_type"/>
                <field name="state"/>
                <field name="plan_start_date"/>
                <field name="plan_end_date"/>
                <field name="sale_order_id"/>
            </list>
        </field>
    </record>

    <record id="view_tynor_ndis_order_search" model="ir.ui.view">
        <field name="name">tynor.ndis.order.search</field>
        <field name="model">tynor.ndis.order</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="ndis_number"/>
                <field name="participant_name"/>
                <field name="state"/>
                <filter name="filter_new" string="New" domain="[('state','=','new')]"/>
                <filter name="filter_processing" string="Processing" domain="[('state','=','processing')]"/>
                <filter name="filter_order_created" string="Order Created" domain="[('state','=','order_created')]"/>
            </search>
        </field>
    </record>

    <record id="view_tynor_ndis_order_form" model="ir.ui.view">
        <field name="name">tynor.ndis.order.form</field>
        <field name="model">tynor.ndis.order</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_create_sale_order" type="object" string="Create Sale Order" class="btn-primary" invisible="sale_order_id or state in ('cancelled', 'done')"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,processing,order_created,done,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_show_sale_order" type="object" class="oe_stat_button" icon="fa-pencil-square-o" invisible="not sale_order_id">
                            <field name="sale_order_id" widget="statinfo" string="Sale Order"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="ndis_number"/>
                            <field name="plan_type"/>
                            <field name="participant_name"/>
                            <field name="email"/>
                            <field name="invoice_email"/>
                            <field name="phone"/>
                        </group>
                        <group>
                            <field name="date_of_birth"/>
                            <field name="plan_start_date"/>
                            <field name="plan_end_date"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="sale_order_id" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="shipping_address"/>
                        <field name="product_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_tynor_ndis_order" model="ir.actions.act_window">
        <field name="name">NDIS Orders</field>
        <field name="res_model">tynor.ndis.order</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_tynor_ndis_order_search"/>
    </record>

    <menuitem id="menu_tynor_ndis_order" name="NDIS Orders" action="action_tynor_ndis_order" sequence="20" active="False"/>
</odoo>
