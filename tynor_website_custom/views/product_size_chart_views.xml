<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_tynor_size_chart" model="ir.ui.view">
        <field name="name">product.template.form.tynor.size.chart</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="website_sale.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='website_sale']" position="inside">
                <group string="Wholesale Fast Ordering">
                    <group>
                        <field name="tynor_size_chart_title"/>
                        <field name="tynor_size_attribute_id"/>
                        <field name="tynor_enable_bulk_size_order"/>
                    </group>
                    <group string="Size Chart Image">
                        <field
                            name="tynor_size_chart_image"
                            widget="image"
                            class="oe_avatar"
                            options="{'preview_image': 'tynor_size_chart_image'}"
                        />
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
