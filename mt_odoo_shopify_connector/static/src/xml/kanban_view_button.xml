<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="ShopifyImportKanban.Buttons" owl="1">
        <div class="d-inline-flex gap-1" style="margin-left: 5px;">
            <button type="button" t-if="props.resModel == 'product.template'" class="btn btn-primary"
                    t-on-click="onClickShopifyProductImport">
                Import from Shopify
            </button>

            <button type="button" t-if='props.resModel == "res.partner"' class="btn btn-primary"
                    t-on-click="onClickShopifyCustomerImport">
                Import from Shopify
            </button>          
        </div>
    </t>
</templates>
