<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_tynor_bill_ship_labels" model="ir.ui.view">
        <field name="name">account.move.form.tynor.bill.ship.labels</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="(//group[@id='header_left_group']/label[@for='partner_id'])[1]" position="attributes">
                <attribute name="string">Bill To</attribute>
            </xpath>
            <xpath expr="//group[@id='header_left_group']/field[@name='partner_shipping_id']" position="attributes">
                <attribute name="string">Ship To</attribute>
                <attribute name="options">{'no_quick_create': True}</attribute>
                <attribute name="context">{'default_type': 'delivery', 'show_address': False, 'show_vat': False, 'default_parent_id': partner_id}</attribute>
            </xpath>
        </field>
    </record>
</odoo>
