<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- 1. Wholesale VIP Pricelist -->
        <record id="list_b2b_wholesale_vip" model="product.pricelist">
            <field name="name">Wholesale VIP</field>
            <!-- discount_policy deprecated. Deprecated in Odoo 19 -->
            <!-- Add 40% discount for orders >= 10 if needed via rules -->
        </record>

        <!-- 2. Pricelist Item Rule: Minimum Order Quantity (MOQ = 10) with 40% discount -->
        <record id="item_b2b_wholesale_vip" model="product.pricelist.item">
            <field name="pricelist_id" ref="list_b2b_wholesale_vip"/>
            <field name="compute_price">percentage</field>
            <field name="percent_price">40.0</field>
            <field name="min_quantity">10</field>
            <field name="applied_on">3_global</field>
        </record>

        <!-- 3. Payment Term: Net 30 -->
        <record id="payment_term_net_30" model="account.payment.term">
            <field name="name">Net 30 (Pay on Account)</field>
            <field name="note">Payment is due 30 days from the invoice date.</field>
        </record>

        <record id="payment_term_net_30_line" model="account.payment.term.line">
            <field name="payment_id" ref="payment_term_net_30"/>
            <field name="value">percent</field>
            <field name="value_amount">100.0</field>
            <field name="nb_days">30</field>
        </record>
        
        <!-- Enable B2B Reorder on config params (Odoo 16+ trick) -->
        <record id="param_b2b_reorder" model="ir.config_parameter">
            <field name="key">website_sale.b2b_checkout</field>
            <field name="value">True</field>
        </record>
    </data>
</odoo>
