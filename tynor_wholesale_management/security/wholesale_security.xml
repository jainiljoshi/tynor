<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Privilege for Wholesale -->
        <record model="res.groups.privilege" id="res_groups_privilege_wholesale">
            <field name="name">Wholesale</field>
            <field name="sequence">20</field>
            <field name="category_id" ref="base.module_category_sales"/>
        </record>

        <!-- Wholesale Manager Group -->
        <record id="group_wholesale_manager" model="res.groups">
            <field name="name">Wholesale Manager</field>
            <field name="privilege_id" ref="tynor_wholesale_management.res_groups_privilege_wholesale"/>
            <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_salesman_all_leads'))]"/>
            <field name="comment">The user will have full access to wholesale apps and leads.</field>
        </record>
    </data>
</odoo>
