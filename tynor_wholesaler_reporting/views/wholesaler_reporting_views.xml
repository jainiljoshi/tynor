<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_tynor_wholesaler_dashboard" model="ir.actions.client">
        <field name="name">Wholesaler Dashboard</field>
        <field name="tag">tynor_wholesaler_reporting.dashboard</field>
    </record>

    <record id="view_tynor_wholesaler_report_search" model="ir.ui.view">
        <field name="name">tynor.wholesaler.report.search</field>
        <field name="model">tynor.wholesaler.report</field>
        <field name="arch" type="xml">
            <search>
                <field name="invoice_date"/>
                <field name="invoice_datetime"/>
                <field name="payment_method"/>
                <field name="channel"/>
                <field name="partner_id"/>
                <filter name="current_month" string="This Month" domain="[('invoice_date', '&gt;=', context_today().strftime('%%Y-%%m-01'))]"/>
                <separator/>
                <filter string="Date" name="group_invoice_date" domain="[]" context="{'group_by': 'invoice_date:month'}"/>
                <filter string="Payment Method" name="group_payment_method" domain="[]" context="{'group_by': 'payment_method'}"/>
                <filter string="Customer" name="group_partner" domain="[]" context="{'group_by': 'partner_id'}"/>
            </search>
        </field>
    </record>

    <record id="view_tynor_wholesaler_report_list" model="ir.ui.view">
        <field name="name">tynor.wholesaler.report.list</field>
        <field name="model">tynor.wholesaler.report</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0">
                <field name="invoice_date"/>
                <field name="move_id"/>
                <field name="sale_order_id"/>
                <field name="partner_id"/>
                <field name="payment_method"/>
                <field name="product_sales_ex_gst" sum="Product Sales"/>
                <field name="shipping_ex_gst" sum="Shipping"/>
                <field name="gst_collected" sum="GST"/>
                <field name="refunds" sum="Refunds"/>
                <field name="fees_commission" sum="Fees/Comm"/>
                <field name="net_amount" sum="Net"/>
            </list>
        </field>
    </record>

    <record id="view_tynor_wholesaler_report_pivot" model="ir.ui.view">
        <field name="name">tynor.wholesaler.report.pivot</field>
        <field name="model">tynor.wholesaler.report</field>
        <field name="arch" type="xml">
            <pivot string="Wholesaler Report" disable_linking="True">
                <field name="invoice_date" type="row" interval="month"/>
                <field name="payment_method" type="col"/>
                <field name="product_sales_ex_gst" type="measure"/>
                <field name="shipping_ex_gst" type="measure"/>
                <field name="gst_collected" type="measure"/>
                <field name="refunds" type="measure"/>
                <field name="fees_commission" type="measure"/>
                <field name="net_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_tynor_wholesaler_report_graph" model="ir.ui.view">
        <field name="name">tynor.wholesaler.report.graph</field>
        <field name="model">tynor.wholesaler.report</field>
        <field name="arch" type="xml">
            <graph string="Wholesaler Trend" type="bar">
                <field name="invoice_date" type="row" interval="month"/>
                <field name="net_amount" type="measure"/>
                <field name="refunds" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_tynor_wholesaler_report" model="ir.actions.act_window">
        <field name="name">Wholesaler Reporting</field>
        <field name="res_model">tynor.wholesaler.report</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="search_view_id" ref="view_tynor_wholesaler_report_search"/>
        <field name="context">{'pivot_measures': ['net_amount', 'product_sales_ex_gst', 'shipping_ex_gst', 'gst_collected', 'refunds', 'fees_commission']}</field>
    </record>

    <menuitem
        id="menu_tynor_wholesaler_root"
        name="Wholesaler"
        action="action_tynor_wholesaler_dashboard"
        sequence="26"
        groups="base.group_user"
    />

    <menuitem
        id="menu_tynor_wholesaler_dashboard"
        name="Dashboard"
        parent="menu_tynor_wholesaler_root"
        action="action_tynor_wholesaler_dashboard"
        sequence="1"
    />

    <menuitem
        id="menu_tynor_wholesaler_reporting"
        name="Reporting"
        parent="menu_tynor_wholesaler_root"
        action="action_tynor_wholesaler_report"
        sequence="2"
    />

    <menuitem
        id="menu_tynor_wholesaler_payment_journal_map"
        name="Payment Journals"
        parent="menu_tynor_wholesaler_root"
        action="tynor_shopify_inbound_bridge.action_tynor_payment_journal_map"
        groups="account.group_account_manager"
        sequence="3"
    />
</odoo>
