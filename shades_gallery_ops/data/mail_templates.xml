<odoo>
    <data noupdate="1">
        <record id="mail_template_shades_enquiry_auto_reply" model="mail.template">
            <field name="name">Shades Enquiry Auto Reply</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="subject">Thanks for contacting The Shades Gallery</field>
            <field name="email_from">${(user.email_formatted or '')|safe}</field>
            <field name="email_to">${object.email_from}</field>
            <field name="body_html" type="html">
                <div>
                    <p>Hello ${object.contact_name or 'there'},</p>
                    <p>Thank you for your enquiry. We have received your request and our team will contact you shortly to schedule your free in-home measurement.</p>
                    <p>Regards,<br/>The Shades Gallery Team</p>
                </div>
            </field>
        </record>

        <record id="mail_template_shades_stage_update" model="mail.template">
            <field name="name">Shades Installation Stage Update</field>
            <field name="model_id" ref="shades_gallery_ops.model_shades_installation_job"/>
            <field name="subject">Your order update: ${object.sale_order_id.name}</field>
            <field name="email_from">${(user.email_formatted or '')|safe}</field>
            <field name="email_to">${object.partner_id.email}</field>
            <field name="body_html" type="html">
                <div>
                    <p>Hello ${object.partner_id.name or 'Customer'},</p>
                    <p>Your order <strong>${object.sale_order_id.name}</strong> is now at stage: <strong>${object.stage}</strong>.</p>
                    <p>We will keep you updated on the next milestones.</p>
                    <p>Regards,<br/>The Shades Gallery Team</p>
                </div>
            </field>
        </record>

        <record id="mail_template_shades_final_payment" model="mail.template">
            <field name="name">Shades Final Payment Reminder</field>
            <field name="model_id" ref="shades_gallery_ops.model_shades_installation_job"/>
            <field name="subject">Final payment reminder for ${object.sale_order_id.name}</field>
            <field name="email_from">${(user.email_formatted or '')|safe}</field>
            <field name="email_to">${object.partner_id.email}</field>
            <field name="body_html" type="html">
                <div>
                    <p>Hello ${object.partner_id.name or 'Customer'},</p>
                    <p>Your installation for order <strong>${object.sale_order_id.name}</strong> is being scheduled.</p>
                    <p>This is a reminder that the remaining balance is due before installation.</p>
                    <p>Regards,<br/>The Shades Gallery Team</p>
                </div>
            </field>
        </record>
    </data>
</odoo>
