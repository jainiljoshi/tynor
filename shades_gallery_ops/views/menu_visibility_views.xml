<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_users_form_shades_hide_menu" model="ir.ui.view">
        <field name="name">res.users.form.shades.hide.menu</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Hide Specific Menus">
                    <field name="hide_menu_ids" widget="many2many_tags"/>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_menu_form_shades_restrict_users" model="ir.ui.view">
        <field name="name">ir.ui.menu.form.shades.restrict.users</field>
        <field name="model">ir.ui.menu</field>
        <field name="inherit_id" ref="base.edit_menu_access"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Restricted Users">
                    <field name="restrict_user_ids" widget="many2many_tags"/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
