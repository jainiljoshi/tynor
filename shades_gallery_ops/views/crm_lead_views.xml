<odoo>
    <record id="view_crm_lead_form_shades_source" model="ir.ui.view">
        <field name="name">crm.lead.form.shades.source</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='email_from']" position="after">
                <field name="shades_lead_source"/>
            </xpath>
            <xpath expr="//field[@name='description']" position="after">
                <field name="shades_interaction_notes" placeholder="Call notes, WhatsApp summary, client interactions..."/>
            </xpath>
        </field>
    </record>
</odoo>
